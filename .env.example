# LLM: use free Gemini by default (get key at https://aistudio.google.com/apikey)
LLM_PROVIDER=auto
GEMINI_API_KEY=

# Optional paid alternative
OPENAI_API_KEY=

# Optional — better market research (https://tavily.com)
TAVILY_API_KEY=

DATABASE_URL=sqlite+aiosqlite:///./dev.db
GITHUB_TOKEN=
GITHUB_REPO=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=10
SEED_ON_STARTUP=true
